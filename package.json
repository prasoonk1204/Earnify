{
  "name": "earnify",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "dev:web": "pnpm --filter @earnify/web dev",
    "dev:api": "pnpm --filter @earnify/api dev",
    "build": "pnpm db:generate && pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,yml,yaml}\"",
    "test": "pnpm --filter @earnify/api test",
    "db:generate": "pnpm --filter @earnify/db db:generate",
    "db:migrate": "pnpm --filter @earnify/db db:migrate",
    "db:seed": "pnpm --filter @earnify/db db:seed",
    "theme:build": "pnpm --filter @earnify/web theme:build",
    "soroban:invoke": "ts-node --esm scripts/invoke-contract.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.3.0"
  }
}
