generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  FOUNDER
  USER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ENDED
}

enum SocialPlatform {
  TWITTER
  LINKEDIN
  INSTAGRAM
}

enum PostStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PayoutStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  avatar        String?
  role          UserRole
  walletAddress String?
  createdAt     DateTime   @default(now())
  campaigns     Campaign[]
  posts         Post[]
  scores        Score[]
  payouts       Payout[]
  participations CampaignParticipant[]
}

model Campaign {
  id                      String         @id @default(cuid())
  title                   String
  description             String
  productUrl              String?
  budget                  String         @default("0")
  budgetToken             String         @default("XLM")
  platforms               String[]
  requiredKeywords        String[]
  startDate               DateTime?
  endDate                 DateTime?
  totalBudget             Decimal        @db.Decimal(12, 2)
  remainingBudget         Decimal        @db.Decimal(12, 2)
  status                  CampaignStatus @default(DRAFT)
  founderId               String
  founder                 User           @relation(fields: [founderId], references: [id], onDelete: Cascade)
  contractId              String?
  stellarContractId       String?
  fundingTxHash           String?
  founderWalletAddress    String?
  stellarWalletPublicKey  String         @default("")
  stellarWalletSecretKeyEncrypted String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  endsAt                  DateTime?
  posts                   Post[]
  scores                  Score[]
  payouts                 Payout[]
  participants            CampaignParticipant[]

  @@index([founderId])
  @@index([status])
}

model Post {
  id                String         @id @default(cuid())
  campaignId        String
  campaign          Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  postUrl           String
  postExternalId    String?
  platform          SocialPlatform
  status            PostStatus     @default(PENDING)
  authenticityScore Float?
  rejectionReason   String?
  lastFetchedAt     DateTime?
  createdAt         DateTime       @default(now())
  engagements       PostEngagement[]
  scores            Score[]

  @@index([campaignId])
  @@index([userId])
}

model PostEngagement {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  views     Int      @default(0)
  likes     Int      @default(0)
  shares    Int      @default(0)
  comments  Int      @default(0)
  fetchedAt DateTime @default(now())

  @@index([postId])
}

model Score {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalScore  Float
  scoreTxHash String?
  updatedAt   DateTime @updatedAt

  @@unique([postId, userId, campaignId])
  @@index([campaignId])
  @@index([userId])
}

model Payout {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId    String
  campaign      Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(12, 2)
  stellarTxHash String?
  status        PayoutStatus @default(PENDING)
  createdAt     DateTime     @default(now())

  @@index([userId])
  @@index([campaignId])
}

model CampaignParticipant {
  id                String   @id @default(cuid())
  campaignId        String
  campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalScore        Float    @default(0)
  estimatedEarnings Float    @default(0)
  rank              Int      @default(0)
  joinedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
}
