# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------------------------
# Local Docker Postgres (dev only)
# ------------------------------------------------------------------------------
POSTGRES_USER=earnify
POSTGRES_PASSWORD=earnify
POSTGRES_DB=earnify
POSTGRES_PORT=5433

# ------------------------------------------------------------------------------
# Database (Prisma + API)
# Local:
# DATABASE_URL=postgresql://earnify:earnify@localhost:5433/earnify?schema=public
# Neon (production): use the pooled connection string from Neon dashboard
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://earnify:earnify@localhost:5433/earnify?schema=public
DIRECT_URL=postgresql://earnify:earnify@localhost:5433/earnify?schema=public

# ------------------------------------------------------------------------------
# Redis
# Local:
# REDIS_URL=redis://localhost:6379
# Upstash (production): use the TLS URL, e.g.
# REDIS_URL=rediss://default:<PASSWORD>@<YOUR-UPSTASH-ENDPOINT>:6379
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Optional alias supported by API:
UPSTASH_REDIS_URL=

# ------------------------------------------------------------------------------
# Ports
# ------------------------------------------------------------------------------
API_PORT=4000
WEB_PORT=3000

# ------------------------------------------------------------------------------
# Frontend <-> API URLs
# NEXT_PUBLIC_API_BASE_URL is used by the web app.
# Keep NEXT_PUBLIC_API_URL for legacy fallback usage in Leaderboard.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ------------------------------------------------------------------------------
# CORS / auth redirects
# For production, set CORS_ORIGINS to your frontend domains (comma-separated).
# Example:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
# ------------------------------------------------------------------------------
WEB_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
WEB_AUTH_SUCCESS_REDIRECT=http://localhost:3000/dashboard

# Optional: protects /api/internal/cron/engagement-refresh.
# For Vercel Cron, set the same value in project env as CRON_SECRET.
CRON_SECRET=

# ------------------------------------------------------------------------------
# JWT / cookies
# In production with Vercel frontend + separate backend domain:
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_SECURE=true
# ------------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=earnify_token
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false

# ------------------------------------------------------------------------------
# Google OAuth
# Set callback to your backend URL:
# e.g. https://your-backend.onrender.com/api/auth/google/callback
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Comma-separated list of founder emails that should get FOUNDER role on login.
FOUNDER_EMAILS=alice@earnify.io

# ------------------------------------------------------------------------------
# Social platform API credentials (engagement fetcher)
# Twitter/X: create a project at https://developer.twitter.com and copy the
#   Bearer Token from the "Keys and Tokens" tab.
# Instagram: obtain an access token via the Instagram Basic Display API or
#   Facebook Graph API (required for like/comment counts on public posts).
# ------------------------------------------------------------------------------
TWITTER_BEARER_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# ------------------------------------------------------------------------------
# AI verification service
# ------------------------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# Stellar payout encryption
# ------------------------------------------------------------------------------
STELLAR_ENCRYPTION_KEY=replace-with-a-long-random-secret

# ------------------------------------------------------------------------------
# Stellar Soroban (testnet)
# ------------------------------------------------------------------------------
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_ADMIN_SECRET=
SOROBAN_CONTRACT_ID=
SOROBAN_WASM_PATH=contracts/earnify-campaign/target/wasm32-unknown-unknown/release/earnify_campaign.optimized.wasm
